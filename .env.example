# Environment variables — copy to .env and fill in
# NEVER commit .env to git!

# Target application
TARGET_REPO=gothinkster/flask-realworld-example-app
TARGET_COMMIT=4b95fb2227dfeb5dd1a45d89b2bf48630b93fd28

# SonarQube
SONAR_HOST_URL=http://localhost:9000
SONAR_TOKEN=your-sonarqube-token-here
SONAR_PROJECT_KEY=conduit-devsecops

# Application secrets
SECRET_KEY=change-me-in-production-use-a-real-secret
DATABASE_URL=postgresql://conduit:conduit@db:5432/conduit

# Quality gates
MIN_COVERAGE=60

# GitHub
GITHUB_TOKEN=your-github-token-for-code-scanning-upload

# Optional: OWASP ZAP
ZAP_API_KEY=optional-zap-api-key
